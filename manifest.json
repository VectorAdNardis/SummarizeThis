{
  "manifest_version": 3,
  "name": "Summarize This",
  "version": "1.1.0",
  "description": "Summarize any web page or PDF using your local LLM",
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "host_permissions": ["http://localhost/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
